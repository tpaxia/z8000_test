  66 00a8 5E080000 	        jp      test_code           ! Jump to test code (0x0200)
  66      0200
  67              	# Bootstrap code ends at 0x00AE
  68              	
  69              	# Dump routine at 0x00C0
  70              	# Saves R0-R15 to reg_dump (0x0140-0x015F), FCW to fcw_dump (0x0162)
  71 00ae 00000000 	        .org    0x00C0
  71      00000000 
  71      00000000 
  71      00000000 
  71      0000
  72              	dump_routine:
  73 00c0 6F000000 	        ld      reg_dump+0, r0      ! Save R0 first (before clobbering)
  73      0140
  74 00c6 7D02     	        ldctl   r0, fcw             ! Read FCW into R0
  75 00c8 6F000000 	        ld      fcw_dump, r0        ! Save FCW at 0x0162
  75      0162
