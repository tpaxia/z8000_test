Zilog Z8000 GAS  bootstrap_seg.s 			page 1


   1              	# Z8000 Test Harness Bootstrap and Dump Routines (Segmented Mode)
   2              	# Assembler: z8k-coff-as -z8001
   3              	#
   4              	# In segmented mode, all DA (direct address) instructions encode as 3 words
   5              	# (opcode + segment word + offset word), making the code larger than the
   6              	# non-segmented version. The bootstrap code extends from 0x0040 to ~0x00AD,
   7              	# so the register dump area is placed at 0x0140 (after the dump routine)
   8              	# instead of 0x0090 as in the non-segmented version.
   9              	#
  10              	# Memory layout:
  11              	#   0x0000-0x0007  Reset vectors (segmented: 4 words)
  12              	#   0x0010-0x002F  Register initial values (loaded by bootstrap)
  13              	#   0x0030-0x0031  FCW setup word
  14              	#   0x0040-0x00AD  Bootstrap code (loads regs, jumps to test code)
  15              	#   0x00C0-0x0133  Dump routine (saves regs after test)
  16              	#   0x0140-0x015F  Register dump area (R0-R15 saved here)
  17              	#   0x0160-0x0161  Done flag
  18              	#   0x0162-0x0163  FCW dump
  19              	#   0x0200+        Test code
  20              	#
  21              	# FCW = 0xC000 (System + Segmented mode)
  22              	
  23              	        segm
  24              	        .text
  25              	        .global _start
  26              	
  27              	# Reset vectors at 0x0000 (segmented format: 4 words)
  28              	        .org    0x0000
  29 0000 0000     	        .word   0x0000          ! Reserved
  30 0002 C000     	        .word   0xC000          ! FCW = System mode + Segmented
  31 0004 0000     	        .word   0x0000          ! PC segment number = 0
  32 0006 0040     	        .word   0x0040          ! PC offset = bootstrap entry
  33              	
  34              	# Register initial values (loaded to R0-R15 by bootstrap)
  35 0008 00000000 	        .org    0x0010
  35      00000000 
  36              	reg_setup:
  37 0010 00000000 	        .space  32              ! R0-R15 initial values (0x0010-0x002F)
  37      00000000 
  37      00000000 
  37      00000000 
  37      00000000 
  38              	
  39              	# FCW setup at 0x0030
  40              	        .org    0x0030
  41              	fcw_setup:
  42 0030 C000     	        .word   0xC000          ! Initial FCW (System + Segmented)
  43              	
  44              	# Bootstrap code at 0x0040
  45 0032 00000000 	        .org    0x0040
  45      00000000 
  45      00000000 
  45      0000
  46              	bootstrap:
  47              	_start:
  48 0040 61000000 	        ld      r0, fcw_setup       ! Load desired FCW value
  48      0030
